ulation' is set to 'Success' and 'Failure')\nResult Analysis :          handle_manipulation = 'AUDIT_NONE' failed test of 'equals' compared to 'AUDIT_SUCCESS_FAILURE' \n","fix_text":"Configure the policy value for Computer Configuration &gt;&gt; Windows Settings &gt;&gt; Security Settings &gt;&gt; Advanced Audit Policy Configuration &gt;&gt; System Audit Policies &gt;&gt; Object Access &gt;&gt; \"Audit Handle Manipulation\" with \"Success\" selected.","classification":"Unclassified","ccis":["CCI-000172"]},{"check_content_ref":{"name":"oval:mil.disa.stig.windows11:def:278930","href":"U_MS_Windows_11_V2R7_STIG_SCAP_1-4_Benchmark-enhancedV16-oval.xml"},"group_id":"V-278930","comments":null,"legacy_ids":[],"severity":"medium","group_tree":{"title":"SRG-OS-000062-GPOS-00031","id":"V-278930"},"false_positives":"","responsibility":"","rule_title":"Windows 11 must be configured to audit registry failures.","potential_impacts":"","status":"open","rule_id_src":"SV-278930r1135308_rule","group_title":"SRG-OS-000062-GPOS-00031","weight":"10.0","group_id_src":"V-278930","reference_identifier":"5471","mitigation_control":"","rule_version":"WN11-AU-000589","third_party_tools":"","classification":"Unclassified","ccis":["CCI-000172"],"finding_details":"Tool: cpe:/a:niwc:scc:5.14\nTime         : 2026-03-16T08:20:30\nResult: failRule Result     : Fail\nCriteria        : false (All child tests must be true. (AND))\nCriteria        :   false (One or more child tests must be true. (OR))\nTest            :     false ('Audit Registry' is set to 'Failure')\nResult Analysis :          registry = 'AUDIT_NONE' failed test of 'equals' compared to 'AUDIT_FAILURE' \nTest            :     false ('Audit Registry' is set to 'Success' and 'Failure')\nResult Analysis :          registry = 'AUDIT_NONE' failed test of 'equals' compared to 'AUDIT_SUCCESS_FAILURE' \n","fix_text":"Configure the policy value for Computer Configuration &gt;&gt; Windows Settings &gt;&gt; Security Settings &gt;&gt; Advanced Aud