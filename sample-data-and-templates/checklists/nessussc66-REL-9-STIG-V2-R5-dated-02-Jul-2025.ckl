          <VULN_ATTRIBUTE>STIGRef</VULN_ATTRIBUTE>
          <ATTRIBUTE_DATA>Red Hat Enterprise Linux 9 Security Technical Implementation Guide :: Version 2, Release: 5 Benchmark Date: 02 Jul 2025</ATTRIBUTE_DATA>
        </STIG_DATA>
        <STIG_DATA>
          <VULN_ATTRIBUTE>TargetKey</VULN_ATTRIBUTE>
          <ATTRIBUTE_DATA>5551</ATTRIBUTE_DATA>
        </STIG_DATA>
