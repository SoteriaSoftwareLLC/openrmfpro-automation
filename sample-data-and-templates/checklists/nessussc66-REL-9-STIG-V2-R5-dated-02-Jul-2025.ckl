          29: 110 92 253:2 / /var/tmp rw,nosuid,nodev,noexec,relatime shared:58 - xfs /dev/mapper/rhel-var_tmp rw,seclabel,attr2,inode64,logbufs=8,logbsize=32k,noquota</FINDING_DETAILS>
