        <STIG_DATA>
          <VULN_ATTRIBUTE>Vuln_Num</VULN_ATTRIBUTE>
          <ATTRIBUTE_DATA>V-258190</ATTRIBUTE_DATA>
        </STIG_DATA>
        <STIG_DATA>
