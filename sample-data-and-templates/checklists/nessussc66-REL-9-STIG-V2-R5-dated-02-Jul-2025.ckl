        <STIG_DATA>
          <VULN_ATTRIBUTE>Vuln_Num</VULN_ATTRIBUTE>
          <ATTRIBUTE_DATA>V-258177</ATTRIBUTE_DATA>
        </STIG_DATA>
        <STIG_DATA>
