        <STIG_DATA>
          <VULN_ATTRIBUTE>Fix_Text</VULN_ATTRIBUTE>
          <ATTRIBUTE_DATA>Edit the file "/etc/passwd" and provide each interactive user account that has a duplicate UID with a unique UID.</ATTRIBUTE_DATA>
