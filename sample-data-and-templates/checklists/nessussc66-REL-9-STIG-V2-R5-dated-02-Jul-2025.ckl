          <ATTRIBUTE_DATA />
        </STIG_DATA>
        <STIG_DATA>
          <VULN_ATTRIBUTE>False_Negatives</VULN_ATTRIBUTE>
          <ATTRIBUTE_DATA />
        </STIG_DATA>
        <STIG_DATA>
          <VULN_ATTRIBUTE>Documentable</VULN_ATTRIBUTE>
          <ATTRIBUTE_DATA>false</ATTRIBUTE_DATA>
        </STIG_DATA>
        <STIG_DATA>
          <VULN_ATTRIBUTE>Mitigations</VULN_ATTRIBUTE>
          <ATTRIBUTE_DATA />
        </STIG_DATA>
        <STIG_DATA>
